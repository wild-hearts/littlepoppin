# Little Poppin store — environment variables (set these in Vercel -> Settings -> Environment Variables).
# NEVER commit real keys. This file documents the names only.

# Stripe secret key. Use a RESTRICTED key with "Checkout Sessions: write".
# Test mode starts with sk_test_..., live mode with sk_live_...
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret from Stripe -> Developers -> Webhooks -> (your endpoint).
# Starts with whsec_...
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: email Naomi a fulfilment notice on each order (via Resend).
# The "from" domain must be verified in Resend (e.g. littlepoppin.com).
RESEND_API_KEY=
ORDER_NOTIFY_EMAIL=

# Optional: force the site origin used for success/cancel/product-image URLs.
# Auto-detected from the request when unset.
SITE_URL=https://littlepoppin.com
